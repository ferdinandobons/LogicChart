{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:logicchart:schema:logic-flow:1.1",
  "title": "LogicChart Logical Model",
  "description": "Canonical decision-flow artifact generated from source code.",
  "type": "object",
  "required": [
    "schema_version",
    "generated_at",
    "root",
    "flows",
    "findings",
    "files",
    "metadata"
  ],
  "properties": {
    "schema_version": {
      "const": "1.1"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "root": {
      "type": "string"
    },
    "flows": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/flow"
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/finding"
      }
    },
    "files": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/file"
      }
    },
    "metadata": {
      "type": "object"
    }
  },
  "$defs": {
    "location": {
      "type": "object",
      "required": ["path", "start_line", "end_line"],
      "properties": {
        "path": {
          "type": "string"
        },
        "start_line": {
          "type": "integer",
          "minimum": 1
        },
        "end_line": {
          "type": "integer",
          "minimum": 1
        }
      },
      "additionalProperties": false
    },
    "node": {
      "type": "object",
      "required": [
        "id",
        "kind",
        "label",
        "location",
        "evidence",
        "detail",
        "metadata"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "kind": {
          "enum": ["entry", "action", "decision", "call", "terminal", "error"]
        },
        "label": {
          "type": "string"
        },
        "location": {
          "$ref": "#/$defs/location"
        },
        "evidence": {
          "$ref": "#/$defs/evidence"
        },
        "detail": {
          "type": "string"
        },
        "metadata": {
          "type": "object"
        }
      },
      "additionalProperties": false
    },
    "edge": {
      "type": "object",
      "required": ["id", "source", "target", "label", "evidence"],
      "properties": {
        "id": {
          "type": "string"
        },
        "source": {
          "type": "string"
        },
        "target": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "evidence": {
          "$ref": "#/$defs/evidence"
        }
      },
      "additionalProperties": false
    },
    "flow": {
      "type": "object",
      "required": [
        "id",
        "name",
        "symbol",
        "language",
        "framework",
        "entry_kind",
        "is_entrypoint",
        "location",
        "nodes",
        "edges",
        "calls",
        "called_by",
        "tests",
        "metadata"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "symbol": {
          "type": "string"
        },
        "language": {
          "enum": [
            "python",
            "typescript",
            "javascript",
            "go",
            "java",
            "csharp",
            "php",
            "c",
            "cpp",
            "rust",
            "ruby"
          ]
        },
        "framework": {
          "type": "string"
        },
        "entry_kind": {
          "type": "string"
        },
        "is_entrypoint": {
          "type": "boolean"
        },
        "location": {
          "$ref": "#/$defs/location"
        },
        "nodes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/node"
          }
        },
        "edges": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/edge"
          }
        },
        "calls": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "called_by": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "tests": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "metadata": {
          "type": "object"
        }
      },
      "additionalProperties": false
    },
    "finding": {
      "type": "object",
      "required": [
        "id",
        "kind",
        "severity",
        "message",
        "evidence",
        "flow_id",
        "location",
        "detail",
        "metadata"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "kind": {
          "type": "string"
        },
        "severity": {
          "enum": ["info", "warning", "error"]
        },
        "message": {
          "type": "string"
        },
        "evidence": {
          "$ref": "#/$defs/evidence"
        },
        "flow_id": {
          "type": "string"
        },
        "location": {
          "$ref": "#/$defs/location"
        },
        "node_id": {
          "type": ["string", "null"]
        },
        "detail": {
          "type": "string"
        },
        "metadata": {
          "type": "object"
        }
      },
      "additionalProperties": false
    },
    "file": {
      "type": "object",
      "required": ["path", "language", "sha256", "flow_ids"],
      "properties": {
        "path": {
          "type": "string"
        },
        "language": {
          "enum": [
            "python",
            "typescript",
            "javascript",
            "go",
            "java",
            "csharp",
            "php",
            "c",
            "cpp",
            "rust",
            "ruby"
          ]
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "flow_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "evidence": {
      "enum": ["VERIFIED", "INFERRED", "POTENTIAL_GAP"]
    }
  },
  "additionalProperties": false
}
