{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:logicchart:schema:logic-flow:2.0",
  "title": "LogicChart Logical Model",
  "description": "Canonical decision-flow artifact generated from source code.",
  "type": "object",
  "required": [
    "schema_version",
    "generated_at",
    "root",
    "flows",
    "files",
    "metadata"
  ],
  "properties": {
    "schema_version": {
      "const": "2.0"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "root": {
      "type": "string"
    },
    "flows": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/flow"
      }
    },
    "files": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/file"
      }
    },
    "metadata": {
      "$ref": "#/$defs/project_metadata"
    }
  },
  "$defs": {
    "string_array": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "non_negative_integer": {
      "type": "integer",
      "minimum": 0
    },
    "ratio": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "json_value": {
      "description": "Detector-specific structured metadata value.",
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "boolean"
        },
        {
          "type": "number"
        },
        {
          "type": "string"
        },
        {
          "type": "array"
        },
        {
          "type": "object"
        }
      ]
    },
    "location": {
      "type": "object",
      "required": ["path", "start_line", "end_line"],
      "properties": {
        "path": {
          "type": "string"
        },
        "start_line": {
          "type": "integer",
          "minimum": 1
        },
        "end_line": {
          "type": "integer",
          "minimum": 1
        }
      },
      "additionalProperties": false
    },
    "node": {
      "type": "object",
      "required": [
        "id",
        "kind",
        "label",
        "location",
        "evidence",
        "detail",
        "metadata"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "kind": {
          "enum": ["entry", "action", "decision", "call", "terminal", "error"]
        },
        "label": {
          "type": "string"
        },
        "location": {
          "$ref": "#/$defs/location"
        },
        "evidence": {
          "$ref": "#/$defs/evidence"
        },
        "detail": {
          "type": "string"
        },
        "metadata": {
          "type": "object"
        }
      },
      "additionalProperties": false
    },
    "edge": {
      "type": "object",
      "required": ["id", "source", "target", "label", "evidence"],
      "properties": {
        "id": {
          "type": "string"
        },
        "source": {
          "type": "string"
        },
        "target": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "evidence": {
          "$ref": "#/$defs/evidence"
        }
      },
      "additionalProperties": false
    },
    "flow": {
      "type": "object",
      "required": [
        "id",
        "name",
        "symbol",
        "language",
        "framework",
        "entry_kind",
        "is_entrypoint",
        "location",
        "nodes",
        "edges",
        "calls",
        "called_by",
        "tests",
        "metadata"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "symbol": {
          "type": "string"
        },
        "language": {
          "enum": [
            "python",
            "typescript",
            "javascript",
            "go",
            "java",
            "csharp",
            "php",
            "c",
            "cpp",
            "rust",
            "ruby"
          ]
        },
        "framework": {
          "type": "string"
        },
        "entry_kind": {
          "type": "string"
        },
        "is_entrypoint": {
          "type": "boolean"
        },
        "location": {
          "$ref": "#/$defs/location"
        },
        "nodes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/node"
          }
        },
        "edges": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/edge"
          }
        },
        "calls": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "called_by": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "tests": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "metadata": {
          "type": "object"
        }
      },
      "additionalProperties": false
    },
    "file": {
      "type": "object",
      "required": ["path", "language", "sha256", "flow_ids"],
      "properties": {
        "path": {
          "type": "string"
        },
        "language": {
          "enum": [
            "python",
            "typescript",
            "javascript",
            "go",
            "java",
            "csharp",
            "php",
            "c",
            "cpp",
            "rust",
            "ruby"
          ]
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "flow_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "dependencies": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "evidence": {
      "enum": ["VERIFIED", "INFERRED", "POTENTIAL_GAP"]
    },
    "project_metadata": {
      "type": "object",
      "properties": {
        "flow_count": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "entrypoint_count": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "languages": {
          "$ref": "#/$defs/string_array"
        },
        "scopes": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/non_negative_integer"
          }
        },
        "enums": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": {
              "$ref": "#/$defs/string_array"
            }
          }
        },
        "quality": {
          "$ref": "#/$defs/quality"
        },
        "language_capabilities": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/language_capability"
          }
        },
        "skipped_files": {
          "$ref": "#/$defs/skipped_files"
        }
      },
      "additionalProperties": true
    },
    "quality": {
      "type": "object",
      "properties": {
        "files": {
          "type": "object"
        },
        "flows": {
          "type": "object"
        },
        "calls": {
          "type": "object"
        },
        "labels": {
          "type": "object"
        },
        "source_locations": {
          "type": "object"
        },
        "graph": {
          "type": "object"
        },
        "languages": {
          "type": "object"
        }
      },
      "additionalProperties": true
    },
    "language_capability": {
      "type": "object",
      "required": ["status", "frontend", "suffixes", "features", "limitations"],
      "properties": {
        "status": {
          "type": "string"
        },
        "frontend": {
          "type": "string"
        },
        "suffixes": {
          "$ref": "#/$defs/string_array"
        },
        "features": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "limitations": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "skipped_files": {
      "oneOf": [
        {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["path", "language", "reason"],
            "properties": {
              "path": {
                "type": "string"
              },
              "language": {
                "type": "string"
              },
              "reason": {
                "type": "string"
              }
            },
            "additionalProperties": true
          }
        },
        {
          "type": "object",
          "required": ["total", "by_reason", "sample"],
          "properties": {
            "total": {
              "$ref": "#/$defs/non_negative_integer"
            },
            "by_reason": {
              "type": "object",
              "additionalProperties": {
                "$ref": "#/$defs/non_negative_integer"
              }
            },
            "sample": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["path", "language", "reason"],
                "properties": {
                  "path": {
                    "type": "string"
                  },
                  "language": {
                    "type": "string"
                  },
                  "reason": {
                    "type": "string"
                  }
                },
                "additionalProperties": true
              }
            }
          },
          "additionalProperties": true
        }
      ]
    }
  },
  "additionalProperties": false
}
